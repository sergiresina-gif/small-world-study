     ]
    }
   ],
   "source": [
    "# Estudiem els extrems\n",
    "Ls_b0, Cs_b0, Ls_norm_b0, Cs_norm_b0 = prop_study(0.1, 0)\n",
    "Ls_b1, Cs_b1, Ls_norm_b1, Cs_norm_b1 = prop_study(0.1, 1)"
   ]
  },
