    "Ns = range(100, 1001, 20)\n",
    "\n",
    "plt.figure(figsize=(12, 5))\n",
    "plt.subplot(1, 2, 1)\n",
    "plt.plot(Ns, Ls_b0, label='L (beta=0)', marker='o')\n",
    "plt.xlabel('N')\n",
    "plt.ylabel('L')\n",
    "plt.title('L vs N (beta=0)')\n",
    "plt.subplot(1, 2, 2)\n",
    "plt.plot(Ns, Cs_b0, label='C (beta=0)', marker='o')\n",
    "plt.xlabel('N')\n",
